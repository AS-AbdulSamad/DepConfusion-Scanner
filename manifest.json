{
  "manifest_version": 3,
  "name": "DepConfusion Scanner",
  "version": "1.0.0",
  "description": "Detect dependency confusion vulnerabilities in web applications and GitHub repositories by analyzing source code, package manifests, and dependency trees.",
  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "https://github.com/*",
    "https://raw.githubusercontent.com/*",
    "https://registry.npmjs.org/*",
    "https://pypi.org/*",
    "https://rubygems.org/*",
    "https://*.nuget.org/*",
    "https://*/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://github.com/*"],
      "js": ["lib/github-analyzer.js"],
      "css": ["lib/github-overlay.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "depconfusion-scanner@security.tool",
      "strict_min_version": "109.0"
    }
  }
}
